generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum ProductSource {
  AMAZON
  FLIPKART
  MYNTRA
  EARNKARO
  OTHER
}
enum PinStatus {
  DRAFT
  GENERATED
  SCHEDULED
  PUBLISHED
  FAILED
}
enum SubscriptionPlan {
  FREE
  CREATOR
  AGENCY
}

model User {
  id                    String                 @id @default(cuid())
  name                  String?
  email                 String?                @unique
  emailVerified         DateTime?
  image                 String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  accounts              Account[]
  sessions              Session[]
  products              Product[]
  generatedPins         GeneratedPin[]
  pinterestAccounts     PinterestAccount[]
  subscriptions         Subscription[]
  apiUsage              ApiUsage[]
  scheduledPosts        ScheduledPost[]
  outfitRecommendations OutfitRecommendation[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime
  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Product {
  id                    String                 @id @default(cuid())
  userId                String
  source                ProductSource
  sourceUrl             String                 @db.Text
  affiliateUrl          String?                @db.Text
  title                 String
  brand                 String?
  price                 Decimal?               @db.Decimal(10, 2)
  currency              String?                @default("INR")
  category              String?
  gender                String?
  fashionStyle          String?
  imageUrls             Json
  metadata              Json?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  user                  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  generatedPins         GeneratedPin[]
  outfitRecommendations OutfitRecommendation[]
  @@index([userId, createdAt])
  @@index([source])
  @@map("products")
}

model GeneratedPin {
  id              String           @id @default(cuid())
  userId          String
  productId       String?
  title           String
  description     String           @db.Text
  tags            Json
  boardSuggestion String?
  status          PinStatus        @default(DRAFT)
  layout          String?
  scheduledFor    DateTime?
  publishedAt     DateTime?
  pinterestPinId  String?
  destinationUrl  String?          @db.Text
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  product         Product?         @relation(fields: [productId], references: [id], onDelete: SetNull)
  images          GeneratedImage[]
  scheduledPosts  ScheduledPost[]
  analytics       Analytics[]
  @@index([userId, status])
  @@index([productId])
  @@map("generated_pins")
}

model GeneratedImage {
  id             String       @id @default(cuid())
  generatedPinId String
  prompt         String       @db.Text
  cloudinaryUrl  String       @db.Text
  publicId       String?
  width          Int          @default(1000)
  height         Int          @default(1500)
  layout         String?
  createdAt      DateTime     @default(now())
  generatedPin   GeneratedPin @relation(fields: [generatedPinId], references: [id], onDelete: Cascade)
  @@index([generatedPinId])
  @@map("generated_images")
}

model PinterestAccount {
  id               String          @id @default(cuid())
  userId           String
  pinterestUserId  String
  username         String?
  encryptedAccess  String          @db.Text
  encryptedRefresh String?         @db.Text
  scopes           String?
  expiresAt        DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  boards           Board[]
  scheduledPosts   ScheduledPost[]
  @@unique([userId, pinterestUserId])
  @@index([userId])
  @@map("pinterest_accounts")
}

model Board {
  id                 String           @id @default(cuid())
  pinterestAccountId String
  pinterestBoardId   String
  name               String
  description        String?          @db.Text
  privacy            String           @default("PUBLIC")
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  pinterestAccount   PinterestAccount @relation(fields: [pinterestAccountId], references: [id], onDelete: Cascade)
  scheduledPosts     ScheduledPost[]
  @@unique([pinterestAccountId, pinterestBoardId])
  @@index([pinterestAccountId])
  @@map("boards")
}

model ScheduledPost {
  id                 String            @id @default(cuid())
  userId             String
  generatedPinId     String
  pinterestAccountId String
  boardId            String
  scheduledFor       DateTime
  status             PinStatus         @default(SCHEDULED)
  failureReason      String?           @db.Text
  jobId              String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  user               User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  generatedPin       GeneratedPin      @relation(fields: [generatedPinId], references: [id], onDelete: Cascade)
  pinterestAccount   PinterestAccount  @relation(fields: [pinterestAccountId], references: [id], onDelete: Cascade)
  board              Board             @relation(fields: [boardId], references: [id], onDelete: Cascade)
  @@index([userId, scheduledFor])
  @@index([status])
  @@map("scheduled_posts")
}

model Analytics {
  id             String       @id @default(cuid())
  generatedPinId String
  date           DateTime
  impressions    Int          @default(0)
  saves          Int          @default(0)
  clicks         Int          @default(0)
  outboundClicks Int          @default(0)
  ctr            Decimal      @default(0) @db.Decimal(6, 4)
  createdAt      DateTime     @default(now())
  generatedPin   GeneratedPin @relation(fields: [generatedPinId], references: [id], onDelete: Cascade)
  @@unique([generatedPinId, date])
  @@index([date])
  @@map("analytics")
}

model Subscription {
  id                 String           @id @default(cuid())
  userId             String
  plan               SubscriptionPlan @default(FREE)
  status             String           @default("active")
  providerCustomerId String?
  providerSubId      String?
  currentPeriodEnd   DateTime?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  user               User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId, status])
  @@map("subscriptions")
}

model ApiUsage {
  id        String   @id @default(cuid())
  userId    String
  route     String
  units     Int      @default(1)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId, createdAt])
  @@index([route])
  @@map("api_usage")
}

model OutfitRecommendation {
  id          String   @id @default(cuid())
  userId      String
  productId   String
  pants       Json
  shoes       Json
  accessories Json
  watches     Json
  aesthetic   String
  rationale   String   @db.Text
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  @@index([userId, createdAt])
  @@index([productId])
  @@map("outfit_recommendations")
}




